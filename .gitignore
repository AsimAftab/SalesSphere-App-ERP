# Miscellaneous
*.class
*.log
*.pyc
*.swp
*.swo
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/
/coverage/
/coverage/lcov.info

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Flutter Version Management (FVM)
.fvm/

# Android
/android/.gradle/
/android/captures/
/android/local.properties
/android/key.properties
/android/build/
/android/app/build/
/android/app/debug/
/android/app/profile/
/android/app/release/
/android/app/google-services.json
/android/app/*.jks
/android/app/*.keystore

# iOS (kept for when iOS support is added later — Android-first today)
/ios/Pods/
/ios/.symlinks/
/ios/Flutter/App.framework
/ios/Flutter/Flutter.framework
/ios/Flutter/Flutter.podspec
/ios/Flutter/Generated.xcconfig
/ios/Flutter/ephemeral/
/ios/Flutter/app.flx
/ios/Flutter/app.zip
/ios/Flutter/flutter_assets/
/ios/Runner/GoogleService-Info.plist
/ios/ServiceDefinitions.json
/ios/Runner/GeneratedPluginRegistrant.*

# SalesSphere — flavor secrets (compile-time --dart-define-from-file inputs).
# Commit *.example versions; never the real ones.
env/dev.json
env/staging.json
env/prod.json
!env/*.example

# Sentry symbols (uploaded via fastlane / EAS later, never committed)
sentry.properties

# Generated code — regenerate after every pull:
#   dart run build_runner build --delete-conflicting-outputs
#   ./tool/gen_dto.sh
#   flutter gen-l10n
**/*.freezed.dart
**/*.g.dart
/lib/core/api/generated/dto/
/lib/l10n/generated/

# Release artifacts
*.apk
*.aab
*.ipa
